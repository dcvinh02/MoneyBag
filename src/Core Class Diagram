classDiagram
    direction BT
    class Transaction {
        <<abstract>>
        - String id
        - double amount
        - LocalDate date
        - String note
        - Category category
        - Wallet wallet
        + getType()* TransactionType
        + getSignedAmount()* double
        + printInfo()* void
    }
    class Income {
        - String source
        + getType() TransactionType
        + getSignedAmount() double
    }
    class Expense {
        - String paymentMethod
        + getType() TransactionType
        + getSignedAmount() double
    }
    class RecurringExpense {
        - Period period
        + nextDueDate() LocalDate
    }

    Income --> Transaction : Extends
    Expense --> Transaction : Extends
    RecurringExpense --> Expense : Extends

    class Wallet {
        <<abstract>>
        - String name
        - double balance
        + deposit(double amount) void
        + withdraw(double amount)* void
        + getWalletType()* WalletType
    }
    class CashWallet {
        + withdraw(double amount) void
    }
    class BankAccount {
        - String bankName
        - String accountNumber
        + withdraw(double amount) void
    }
    class EWallet {
        - String provider
        + withdraw(double amount) void
    }

    CashWallet --> Wallet : Extends
    BankAccount --> Wallet : Extends
    EWallet --> Wallet : Extends